# ==========================================
# 1. Bỏ qua Dữ liệu và Trọng số (QUAN TRỌNG)
# ==========================================
# File text gốc, file jsonl và bộ vocab (Rất nặng, không bao giờ push lên Git)
data/
!data/.gitkeep

# Thư mục chứa các file .pt lưu trọng số của model
checkpoints/
!checkpoints/.gitkeep

# ==========================================
# 2. Bỏ qua Môi trường Python (Virtual Env)
# ==========================================
# Nếu bạn tạo virtual environment trong thư mục dự án
venv/
.venv/
env/
.env/

# ==========================================
# 3. Bỏ qua File Tạm và Cache của Python
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/

# ==========================================
# 4. Bỏ qua File Hệ thống và IDE
# ==========================================
# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code / PyCharm / Jupyter
.vscode/
.idea/
*.ipynb_checkpoints/

# ==========================================
# 5. Bỏ qua Log file (Nếu có dùng sau này)
# ==========================================
*.log
runs/             # Thư mục mặc định của TensorBoard
wandb/            # Thư mục của thư viện Weights & Biases